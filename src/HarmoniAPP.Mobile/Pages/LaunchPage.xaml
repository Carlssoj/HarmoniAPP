<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarmoniAPP.Mobile.Pages.LaunchPage"
             NavigationPage.HasNavigationBar="False"
             SafeAreaEdges="All">

    <Grid Padding="24">
        <VerticalStackLayout VerticalOptions="Center" Spacing="18">
            <Border Style="{StaticResource HeroCardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Harmoni"
                           Style="{StaticResource EyebrowStyle}" />
                    <Label Text="Preparando sua operação comercial."
                           Style="{StaticResource HeroTitleStyle}" />
                    <Label x:Name="StatusLabel"
                           Text="Validando sua sessão mobile..."
                           Style="{StaticResource SecondaryTextStyle}" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="True"
                               HorizontalOptions="Center"
                               Color="{StaticResource BrandPrimary}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
