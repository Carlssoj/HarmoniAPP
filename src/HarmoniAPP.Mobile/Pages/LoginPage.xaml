<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarmoniAPP.Mobile.Pages.LoginPage"
             NavigationPage.HasNavigationBar="False"
             SafeAreaEdges="All">

    <Grid Padding="20,20,20,24"
          RowDefinitions="Auto,*">
        <Border Style="{StaticResource HeroCardStyle}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Harmoni"
                       Style="{StaticResource EyebrowStyle}" />
                <Label Text="Sua operação comercial, pronta para o dia a dia do time."
                       Style="{StaticResource HeroTitleStyle}" />
                <Label Text="Entre com seu usuário do CRM para acessar o resumo, o pipeline, a agenda e as interações."
                       Style="{StaticResource SecondaryTextStyle}" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="0,18,0,0"
                                 Spacing="14">
                <Border Style="{StaticResource FormFieldBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Usuário ou e-mail"
                               Style="{StaticResource FieldLabelStyle}" />
                        <Entry x:Name="LoginEntry"
                               Placeholder="admin ou seu e-mail"
                               Keyboard="Email" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource FormFieldBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Senha"
                               Style="{StaticResource FieldLabelStyle}" />
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Digite sua senha"
                               IsPassword="True" />
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="StatusLabel"
                       IsVisible="False"
                       Style="{StaticResource StatusTextStyle}" />

                <Button x:Name="LoginButton"
                        Text="Entrar no Harmoni"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Clicked="OnLoginClicked" />

                <Label Text="Experiência mobile do Harmoni para acompanhar pipeline, agenda e interações."
                       Style="{StaticResource SecondaryTextStyle}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
