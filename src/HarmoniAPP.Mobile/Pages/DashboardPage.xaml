<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarmoniAPP.Mobile.Pages.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label x:Name="WelcomeLabel"
                   Text="Dashboard Harmoni"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label x:Name="ProfileLabel"
                   FontSize="14"
                   TextColor="#6D5B52" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Padding="12">
                    <VerticalStackLayout>
                        <Label Text="Leads" FontAttributes="Bold" />
                        <Label x:Name="LeadsLabel" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Padding="12">
                    <VerticalStackLayout>
                        <Label Text="Clientes" FontAttributes="Bold" />
                        <Label x:Name="CustomersLabel" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Padding="12">
                    <VerticalStackLayout>
                        <Label Text="Oportunidades" FontAttributes="Bold" />
                        <Label x:Name="OpportunitiesLabel" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Padding="12">
                    <VerticalStackLayout>
                        <Label Text="Tarefas pendentes" FontAttributes="Bold" />
                        <Label x:Name="TasksLabel" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="12">
                    <VerticalStackLayout>
                        <Label Text="Pipeline aberto" FontAttributes="Bold" />
                        <Label x:Name="PipelineLabel" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label Text="Módulos do MVP" FontAttributes="Bold" />

            <Button Text="Leads" Clicked="OnOpenLeadsClicked" />
            <Button Text="Clientes" Clicked="OnOpenCustomersClicked" />
            <Button Text="Oportunidades" Clicked="OnOpenOpportunitiesClicked" />
            <Button Text="Tarefas e agenda" Clicked="OnOpenTasksClicked" />
            <Button Text="Interações" Clicked="OnOpenInteractionsClicked" />
            <Button Text="Perfil" Clicked="OnOpenProfileClicked" />
            <Button Text="Sair" Clicked="OnLogoutClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
