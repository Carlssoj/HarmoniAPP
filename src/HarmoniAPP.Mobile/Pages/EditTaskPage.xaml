<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarmoniAPP.Mobile.Pages.EditTaskPage"
             SafeAreaEdges="All"
             Title="Editar tarefa">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32"
                             Spacing="14">
            <Label Text="Atualize prazos, prioridade e conclusão da tarefa sem sair do app."
                   Style="{StaticResource SecondaryTextStyle}" />

            <Border Style="{StaticResource FormFieldBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Tarefa"
                           Style="{StaticResource FieldLabelStyle}" />
                    <Entry x:Name="TitleEntry"
                           Placeholder="Ex: Revisar proposta" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource FormFieldBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Relacionado a"
                           Style="{StaticResource FieldLabelStyle}" />
                    <Entry x:Name="RelatedToEntry"
                           Placeholder="Conta, oportunidade ou cliente" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Style="{StaticResource FormFieldBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Prioridade"
                               Style="{StaticResource FieldLabelStyle}" />
                        <Picker x:Name="PriorityPicker"
                                Title="Selecione" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource FormFieldBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Data de vencimento"
                               Style="{StaticResource FieldLabelStyle}" />
                        <DatePicker x:Name="DueDatePicker" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Style="{StaticResource FormFieldBorderStyle}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Concluir tarefa"
                               Style="{StaticResource FieldLabelStyle}" />
                        <Label Text="Marque quando a entrega já tiver sido finalizada."
                               Style="{StaticResource SecondaryTextStyle}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            x:Name="CompletedSwitch"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource FormFieldBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Observações"
                           Style="{StaticResource FieldLabelStyle}" />
                    <Editor x:Name="NotesEditor"
                            AutoSize="TextChanges"
                            Placeholder="Pendências, contexto ou dependências da entrega." />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="StatusLabel"
                   IsVisible="False"
                   Style="{StaticResource StatusTextStyle}" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Button Text="Cancelar"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Clicked="OnCancelClicked" />
                <Button Grid.Column="1"
                        x:Name="SaveButton"
                        Text="Salvar alterações"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Clicked="OnSaveClicked" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
