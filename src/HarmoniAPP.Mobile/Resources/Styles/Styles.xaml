<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource AppBackground}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource BrandPrimaryStrong}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BarTextColor" Value="{StaticResource BrandPrimaryStrong}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource BrandPrimary}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="AutoSize" Value="TextChanges" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource BorderSoft}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="22" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroCardStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceSoft}" />
        <Setter Property="Stroke" Value="{StaticResource AccentSoft}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="28" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FormFieldBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}" />
        <Setter Property="TextColor" Value="White" />
    </Style>

    <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource BrandPrimaryStrong}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderSoft}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="EyebrowStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource BrandPrimary}" />
        <Setter Property="TextTransform" Value="Uppercase" />
        <Setter Property="CharacterSpacing" Value="1.4" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="LineHeight" Value="1.1" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="HeroTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="LineHeight" Value="1.1" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="HeroMetricStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="MetricValueStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="CardCaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="TextTransform" Value="Uppercase" />
        <Setter Property="CharacterSpacing" Value="1.1" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="TextTransform" Value="Uppercase" />
        <Setter Property="CharacterSpacing" Value="1.1" />
    </Style>

    <Style x:Key="SecondaryTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="ChipValueStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource BrandPrimaryStrong}" />
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Warning}" />
    </Style>

    <Style x:Key="EmptyStateStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="Padding" Value="24" />
    </Style>

</ResourceDictionary>
